# --- Database (Postgres) ---
DATABASE_URL="postgresql://user:password@host:5432/ifehomes?schema=public"

# --- NextAuth ---
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Cloudinary (image uploads) ---
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# --- Resend (email OTP for signup verification) ---
# Free account at https://resend.com -> API Keys
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="Ife Homes <onboarding@resend.dev>"

# --- Twilio Verify (optional — only needed if you want to offer phone-SMS OTP too) ---
# Free trial credits at https://twilio.com -> create a Verify Service
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""
# Set to "true" only once the three Twilio values above are filled in —
# this is what shows the "verify with phone" option on the signup form.
NEXT_PUBLIC_ENABLE_PHONE_VERIFY="false"

# --- Admin ---
# The email address that should have access to /admin (approving agent payments).
# Use the email of whichever account you sign up with as the site owner.
ADMIN_EMAIL="you@example.com"
